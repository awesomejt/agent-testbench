# Docker Compose environment — copy to .env and adjust as needed
# Add to /etc/hosts for local dev:
#   127.0.0.1  testbench.local  api.testbench.local

POSTGRES_USER=testbench
POSTGRES_PASSWORD=testbench
POSTGRES_DB=testbench

# URL the React app uses to reach the API (baked in at build time)
VITE_API_URL=https://api.testbench.local

# Overrides the PROJECT_NAME default set in the Makefile (agent-testbench)
# PROJECT_NAME=agent-testbench

# Harbor registry prefix for deploy targets (host/project, no trailing slash)
# HARBOR_REGISTRY=harbor.example.com/testbench
